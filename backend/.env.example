# ─────────────────────────────────────────────
# MediFlow Backend — Environment Variables
# ─────────────────────────────────────────────
# Copy this to .env and fill in real values.
# NEVER commit .env to git.

# ── Direct PostgreSQL connection (for all data queries) ──
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# IMPORTANT: URL-encode special chars in password:  # → %23   @ → %40
DATABASE_URL=postgresql://postgres.your-project-id:%23YourPass%40word@aws-0-region.pooler.supabase.com:6543/postgres

# ── Supabase REST API (used ONLY for auth: login, OTP, JWT verify) ──
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Server config ──
PORT=3001
FRONTEND_URL=http://localhost:8080
