# Backend / Server-side environment variables
# These are NOT exposed to the browser — keep them secret!

# Supabase project URL (same as frontend)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable/anon key (safe to use in server middleware)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase service role key — NEVER expose to client code!
# Used only for admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
