# Frontend environment variables
# Copy this file to .env and fill in your values.
# Only VITE_ prefixed vars are exposed to the browser bundle.

# Supabase project URL — safe to expose (public endpoint)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable (anon) key — safe to expose, RLS enforces access
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase project ID (used for project-specific tooling)
VITE_SUPABASE_PROJECT_ID=your-project-id